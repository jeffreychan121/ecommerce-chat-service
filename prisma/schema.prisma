generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户（通过手机号识别）
model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  ChatSession[]
  leads     Lead[]
}

// 店铺/商户
model Store {
  id              String    @id @default(uuid())
  name            String
  storeType       StoreType
  difyDatasetId   String?   // Dify 知识库 ID
  fileStoragePath String?   // 本地文件存储目录
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        ChatSession[]
  trainingJobs    TrainingJob[]
  leads           Lead[]
}

enum StoreType {
  SELF       // 自营
  MERCHANT   // 第三方店铺
}

// 聊天会话
model ChatSession {
  id                  String        @id @default(uuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  storeId             String
  store               Store         @relation(fields: [storeId], references: [id])
  storeType           StoreType
  channel             String        // 小程序/H5/App
  difyConversationId String?       // Dify 会话ID
  status              SessionStatus @default(OPEN)
  lastActiveAt        DateTime      @default(now())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  messages       ChatMessage[]
  handoffTickets HandoffTicket[]
}

enum SessionStatus {
  OPEN     // AI 对话中
  HANDOFF  // 已转人工
  CLOSED   // 会话已关闭
}

// 聊天消息
model ChatMessage {
  id          String      @id @default(uuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderType  SenderType
  content     String
  messageType MessageType @default(TEXT)
  rawPayload  Json?       // Dify 原始响应
  createdAt   DateTime   @default(now())
}

enum SenderType {
  USER    // 用户
  AI      // AI
  HUMAN   // 人工客服
  SYSTEM  // 系统消息
}

enum MessageType {
  TEXT   // 文本
  EVENT  // 事件（如转人工）
  CARD   // 卡片（如订单卡片）
}

// 转人工工单
model HandoffTicket {
  id              String        @id @default(uuid())
  sessionId       String
  session         ChatSession   @relation(fields: [sessionId], references: [id])
  status          HandoffStatus @default(PENDING)
  queueNo         Int           // 排队号
  assignedAgentId String?       // 分配的客服ID
  agentJoinedAt   DateTime?     // 客服接入时间
  closedAt        DateTime?     // 关闭时间
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum HandoffStatus {
  PENDING  // 待接单
  ANSWERED // 已接单
  CLOSED   // 已关闭
}

// 导购留资
model Lead {
  id          String    @id @default(uuid())
  userId      String    // 用户ID
  user        User      @relation(fields: [userId], references: [id])
  storeId     String    // 店铺ID
  store       Store     @relation(fields: [storeId], references: [id])
  skuId       String    // 商品SKU
  skuName     String    // 商品名称
  quantity    Int       @default(1) // 购买数量
  price       Float     // 商品单价
  intent      LeadIntent // 意向类型
  userPhone   String    // 用户手机号（冗余，方便查看）
  status      LeadStatus @default(PENDING) // 留资状态
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum LeadIntent {
  BUY      // 购买意向
  CONSULT  // 咨询
  COMPARE  // 比价
}

enum LeadStatus {
  PENDING    // 待处理
  CONTACTED  // 已联系
  CLOSED     // 已关闭
}

// 订单
model Order {
  id              String      @id @default(uuid())
  orderNo         String      @unique // DD开头的订单号
  status          OrderStatus @default(PENDING)
  payStatus       PayStatus   @default(UNPAID)
  amount          Float       @default(0)      // 订单金额
  discountAmount Float      @default(0)      // 优惠金额
  actualAmount   Float       @default(0)      // 实付金额
  quantity       Int         @default(1)      // 商品数量
  productName    String                     // 商品名称
  productPrice  Float       @default(0)      // 商品单价
  shippingAddress String?                    // 收货地址
  receiverName   String?                    // 收货人
  receiverPhone String?                    // 联系电话
  createdAt     DateTime    @default(now())
  paidAt         DateTime?                   // 支付时间
  shippedAt     DateTime?                   // 发货时间
  deliveredAt   DateTime?                   // 送达时间
  updatedAt     DateTime    @updatedAt

  // 物流信息
  logistics  Logistics?
}

enum OrderStatus {
  PENDING       // 待支付
  PAID          // 已支付
  TO_BE_SHIPPED // 待发货
  SHIPPED       // 已发货
  DELIVERED    // 已送达
  CANCELLED     // 已取消
  REFUNDED     // 已退款
}

enum PayStatus {
  UNPAID   // 未支付
  PAID     // 已支付
  REFUNDED // 已退款
}

// 物流信息
model Logistics {
  id          String        @id @default(uuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier     String                      // 快递公司
  trackingNo  String                      // 运单号
  status      LogisticsStatus @default(PENDING)
  currentLocation String?                 // 当前所在地
  estimatedDelivery DateTime?            // 预计送达时间
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // 物流轨迹
  events     LogisticsEvent[]
}

enum LogisticsStatus {
  PENDING    // 待发货
  IN_TRANSIT // 运输中
  DELIVERED  // 已送达
}

// 物流轨迹节点
model LogisticsEvent {
  id          String   @id @default(uuid())
  logisticsId String
  logistics  Logistics @relation(fields: [logisticsId], references: [id], onDelete: Cascade)
  time        DateTime @default(now())
  location   String
  description String
}

// 训练任务状态
enum TrainingStatus {
  PENDING     // 待处理
  PROCESSING  // 处理中
  COMPLETED   // 已完成
  FAILED      // 失败
}

// 训练任务
model TrainingJob {
  id             String        @id @default(uuid())
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id])
  fileName       String
  filePath       String        // 本地文件路径
  difyDocumentId String?       // Dify 知识库文档ID
  enabled        Boolean       @default(true)  // 是否启用
  status         TrainingStatus @default(PENDING)
  errorMessage   String?
  createdAt      DateTime      @default(now())
  completedAt    DateTime?
}